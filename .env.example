# Copy this file to .env and fill values.

# AI Brain / Vision
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GROQ_API_KEY=your_groq_api_key

# Voice
ELEVENLABS_API_KEY=your_elevenlabs_api_key
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=your_azure_region

# Wake word
PICOVOICE_ACCESS_KEY=your_picovoice_access_key

# Optional integrations
OPENWEATHER_API_KEY=your_openweather_key
GOOGLE_SEARCH_API_KEY=your_google_search_key
GOOGLE_CSE_ID=your_custom_search_engine_id

# Runtime config
JARVIS_AI_PROVIDER=local
JARVIS_LOCAL_MODEL=llama3.2:3b
JARVIS_LOCAL_AI_URL=http://127.0.0.1:11434
JARVIS_CLOUD_MODEL=gpt-4o-mini
JARVIS_CLOUD_API_BASE_URL=https://api.openai.com/v1
JARVIS_TTS_PROVIDER=edge
JARVIS_TTS_VOICE=en-GB-RyanNeural
JARVIS_STT_PROVIDER=faster_whisper
JARVIS_WAKE_WORD_PROVIDER=manual
JARVIS_WAKE_WORD_PHRASE=hey jarvis
JARVIS_VOICE_ENABLED=true
JARVIS_VISION_PROVIDER=local
JARVIS_PRIVACY_MODE=true
JARVIS_GESTURE_ENABLED=false
JARVIS_GESTURE_CAMERA_INDEX=0
JARVIS_SYSTEM_METRICS_INTERVAL=1.0
JARVIS_AUTO_APPROVE_TOOLS=true
JARVIS_INTERNET_ENABLED=true

# Optional alt local model
# JARVIS_LOCAL_MODEL=phi3.5:latest

# Optional Groq cloud routing (for vision/text cloud tasks)
# JARVIS_CLOUD_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# JARVIS_CLOUD_API_BASE_URL=https://api.groq.com/openai/v1
